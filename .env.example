# Copy this file to .env and fill in your real values.
# .env should NOT be committed to git (it's already in .gitignore).

# Demo endpoint - use when running the local demo_api.py for testing:
API_URL=http://127.0.0.1:5000/demo/api/SystemStatus

# --- Microsoft Teams webhook ---
# Get this from your Power Automate / Teams incoming webhook workflow.
WEBHOOK_URL=https://your-power-automate-webhook-url

# Optional separate Teams webhook for jobs.py / object monitor:
WEBHOOK_URL_Processes_Status=https://your-power-automate-process-webhook-url

# --- IBM i Db2 local connection ---
DB2USER=your-db2-user
DB2PWD=your-db2-password

# SQL used by jobs.py. It must return OBJLIB, OBJNAME, OBJTYPE, and OBJTEXT.
OBJECT_STATS_SQL=SELECT OBJLIB, OBJNAME, OBJTYPE, OBJTEXT FROM YOUR_LIBRARY.YOUR_TABLE
